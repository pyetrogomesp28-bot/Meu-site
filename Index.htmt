<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Kifesta</title>
</head>

<body style="text-align:center; font-family:Arial; background:#ffeef2;">

<h1>Kifesta</h1>

<button onclick="document.getElementById('loja').style.display='block'">
Entrar
</button>

<div id="loja" style="display:none; margin-top:20px;">

<h2>🍿 Pipoca Gourmet</h2>

<button onclick="mostrar('Ninho')">Ninho</button>
<button onclick="mostrar('Chocolate')">Chocolate</button>
<button onclick="mostrar('Nesquik')">Nesquik</button>
<button onclick="mostrar('Morango')">Morango</button>
<button onclick="mostrar('Brigadeiro Colorido')">Brigadeiro Colorido</button>

<h3 id="resposta"></h3>

<hr>

<h2>🍬 Brigadeiros</h2>
<p>Brigadeiro, Beijinho, Bem Casado, Ninho, Coco, Cajuzinho, Crocante, Surpresa de Uva</p>

<p>💰 Personalizado: R$ 1,80</p>
<p>💰 Sem letra: R$ 1,80</p>

</div>

<script>
function mostrar(sabor){
document.getElementById("resposta").innerHTML =
"Você escolheu: " + sabor + "<br>Preço: R$ 3,80";
}
</script>

</body>
</html>
